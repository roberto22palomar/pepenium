# This file is intentionally capability-focused.
# It can be used as a reference layer for Appium-backed mobile profiles:
# - local-android
# - local-android-web
# - aws-android
# - aws-android-web
# - aws-ios
# - browserstack-android
# - browserstack-android-web
# - browserstack-ios
# - browserstack-ios-web

APPIUM_PLATFORM_NAME=Android
APPIUM_AUTOMATION_NAME=UiAutomator2
APPIUM_PLATFORM_VERSION=15
APPIUM_NEW_COMMAND_TIMEOUT=300

APPIUM_AUTO_GRANT_PERMISSIONS=true
APPIUM_NO_RESET=true
APPIUM_FULL_RESET=false
APPIUM_DONT_STOP_APP_ON_RESET=false
APPIUM_SKIP_DEVICE_INITIALIZATION=false
APPIUM_SKIP_SERVER_INSTALLATION=false
APPIUM_IGNORE_HIDDEN_API_POLICY_ERROR=true
APPIUM_AUTO_LAUNCH=true

APPIUM_ADB_EXEC_TIMEOUT=45000
APPIUM_UIAUTOMATOR2_SERVER_LAUNCH_TIMEOUT=90000
APPIUM_UIAUTOMATOR2_SERVER_INSTALL_TIMEOUT=90000
APPIUM_ANDROID_INSTALL_TIMEOUT=120000

APP_WAIT_PACKAGE=com.example.app
APP_WAIT_ACTIVITY=.MainActivity

# Extra Appium capabilities for provider/device-specific tuning.
# Entries use ';' separators and key=value format.
# Unprefixed keys are treated as appium:* capabilities; vendor:* keys are kept as-is.
# PEPENIUM_APPIUM_CAPABILITIES=appWaitDuration=30000;vendor:flag=true;customRetries=3

# Toolkit wait tuning
# PEPENIUM_ACTION_TIMEOUT_SECONDS=10
# PEPENIUM_ACTION_LONG_TIMEOUT_SECONDS=120
# PEPENIUM_ASSERTION_TIMEOUT_SECONDS=6

# iOS-only capability overrides
# APPIUM_PLATFORM_NAME=iOS
# APPIUM_AUTOMATION_NAME=XCUITest
# APPIUM_AUTO_ACCEPT_ALERTS=true
# APPIUM_WDA_LAUNCH_TIMEOUT=60000
# APPIUM_WDA_CONNECTION_TIMEOUT=120000
