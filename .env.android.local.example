# Execution profile
PEPENIUM_PROFILE=local-android

# Local Appium server
APPIUM_URL=http://127.0.0.1:4723

# Local Android device/emulator
ANDROID_UDID=emulator-5554
ANDROID_DEVICE_NAME=Android Emulator

# Choose one app launch strategy:
# 1. Install from artifact
APP_PATH=C:\apps\my-app.apk

# 2. Or launch an already installed app
# APP_PACKAGE=com.example.app
# APP_ACTIVITY=.MainActivity

# Optional advanced Android/Appium capability overrides
# APPIUM_PLATFORM_VERSION=15
# APPIUM_NEW_COMMAND_TIMEOUT=300
# APPIUM_AUTO_GRANT_PERMISSIONS=true
# APPIUM_NO_RESET=true
# APPIUM_FULL_RESET=false
# APPIUM_DONT_STOP_APP_ON_RESET=false
# APPIUM_SKIP_DEVICE_INITIALIZATION=false
# APPIUM_SKIP_SERVER_INSTALLATION=false
# APPIUM_IGNORE_HIDDEN_API_POLICY_ERROR=true
# APPIUM_AUTO_LAUNCH=true
# APPIUM_ADB_EXEC_TIMEOUT=45000
# APPIUM_UIAUTOMATOR2_SERVER_LAUNCH_TIMEOUT=90000
# APPIUM_UIAUTOMATOR2_SERVER_INSTALL_TIMEOUT=90000
# APPIUM_ANDROID_INSTALL_TIMEOUT=120000
# APP_WAIT_PACKAGE=com.example.app
# APP_WAIT_ACTIVITY=.MainActivity

# Diagnostics
# DEVICEFARM_SCREENSHOT_PATH=C:\temp\pepenium-screenshots
# PEPENIUM_DETAIL_LOGGING=false
# PEPENIUM_STEP_TRACKER_LIMIT=10
# PEPENIUM_REPORT_DIR=target\pepenium-reports
