# Build output
target/
**/target/

# IDE and local scratch data
/.idea/
/logs/
/tmp/
/artifacts/

# Local secrets and machine-specific config
*.env

# Local binaries and logs
*.exe
*.log

# Provider-owned runtime YAML may contain credentials. `pepenium.yml` is
# intentionally versionable when it uses environment placeholders.
/.pepenium/
/pepenium-core/src/test/resources/browserstack*.yml
/pepenium-examples/src/test/resources/browserstack*.yml
